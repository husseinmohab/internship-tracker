# .env — Local development environment variables
# Copy this file to .env and fill in your values.
# This file is git-ignored and never committed.
# In GitHub Actions, these are set as repository Secrets instead.

# ── Adzuna API (free) ──────────────────────────────────────────────────
# Sign up: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ── USAJobs API (free) ─────────────────────────────────────────────────
# Sign up: https://developer.usajobs.gov/
USAJOBS_API_KEY=your_usajobs_api_key_here
USAJOBS_EMAIL=your_email@example.com
